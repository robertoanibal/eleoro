---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	canonical?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
}

const {
	title,
	description = "AI workflows built for law firms and accounting practices. Automate client intake, documents, follow-ups, and billing so your team can focus on the work that matters.",
	canonical = new URL(Astro.url.pathname, Astro.site).href,
	ogTitle = title,
	ogDescription = description,
	ogImage = "https://eleoro.com/eleoro-logo-nobg.png",
	ogType = 'website',
} = Astro.props;

const orgSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "eleoro",
	"url": "https://eleoro.com/",
	"logo": "https://eleoro.com/eleoro-logo-nobg.png",
	"sameAs": []
};

const webPageSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"name": title,
	"url": canonical,
	"description": description
};
---

<!DOCTYPE html>
<html lang="en">
<head>
	<!-- Google tag (gtag.js) -->
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-4PQSEM8381"></script>
	<script is:inline>
		window.dataLayer = window.dataLayer || [];
		function gtag() { dataLayer.push(arguments); }
		gtag('js', new Date());
		gtag('config', 'G-4PQSEM8381');
	</script>

	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{title}</title>
	<link rel="canonical" href={canonical}>
	<meta name="description" content={description}>
	<meta name="robots" content="index, follow, max-image-preview:large">
	<link rel="icon" href="/favicon.ico">
	<link rel="apple-touch-icon" href="/apple-touch-icon.png">
	<meta name="theme-color" content="#0f172a">

	<!-- Open Graph -->
	<meta property="og:type" content={ogType} />
	<meta property="og:url" content={canonical} />
	<meta property="og:site_name" content="eleoro" />
	<meta property="og:title" content={ogTitle} />
	<meta property="og:description" content={ogDescription} />
	<meta property="og:image" content={ogImage} />
	<meta property="og:image:width" content="1200" />
	<meta property="og:image:height" content="630" />
	<meta property="og:locale" content="en_US" />

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={ogTitle} />
	<meta name="twitter:description" content={ogDescription} />
	<meta name="twitter:image" content={ogImage} />

	<!-- Structured Data: Organization -->
	<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

	<!-- Structured Data: WebPage (dynamic per page) -->
	<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

	<!-- Page-specific head additions (JSON-LD, etc.) -->
	<slot name="head" />

	<!-- Open source fonts similar to Datavant -->
	<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
	<script crossorigin="anonymous" src="https://kit.fontawesome.com/b632618dd6.js"></script>
</head>
<body>
	<slot />
	<script is:inline src="/script.js"></script>
</body>
</html>
