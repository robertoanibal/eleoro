---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "AI workflows built for law firms and accounting practices. Automate client intake, documents, follow-ups, and billing so your team can focus on the work that matters." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<!-- Google tag (gtag.js) -->
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-4PQSEM8381"></script>
	<script is:inline>
		window.dataLayer = window.dataLayer || [];
		function gtag() { dataLayer.push(arguments); }
		gtag('js', new Date());
		gtag('config', 'G-4PQSEM8381');
	</script>

	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{title}</title>
	<link rel="canonical" href="https://eleoro.com/">
	<meta name="description" content={description}>
	<meta name="robots" content="index, follow, max-image-preview:large">
	<link rel="icon" href="/favicon.ico">
	<link rel="apple-touch-icon" href="/apple-touch-icon.png">
	<meta name="theme-color" content="#0f172a">

	<!-- Structured Data: Organization + WebPage -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "eleoro",
		"url": "https://eleoro.com/",
		"logo": "https://eleoro.com/assets/og/logo.png",
		"sameAs": []
	}
	</script>
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		"name": "eleoro | AI workflows for law firms and CPA practices",
		"url": "https://eleoro.com/",
		"description": "We help law firms and accounting practices automate intake, documents, and follow-ups — and we work with other professional service businesses too."
	}
	</script>

	<!-- Open source fonts similar to Datavant -->
	<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
	<script crossorigin="anonymous" src="https://kit.fontawesome.com/b632618dd6.js"></script>
</head>
<body>
	<slot />
	<script is:inline src="/script.js"></script>
</body>
</html>
