---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSupabaseClient } from '../../lib/supabase';

let message = '';
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString();

    if (email) {
      const supabase = createSupabaseClient(Astro);
      const { error: authError } = await supabase.auth.signInWithOtp({
        email,
        options: {
          emailRedirectTo: `${Astro.url.origin}/portal/auth/callback`,
        },
      });

      if (authError) {
        error = authError.message;
      } else {
        message = 'Check your email for the login link!';
      }
    }
  } catch (e) {
    error = 'An unexpected error occurred.';
  }
}
---

<BaseLayout title="Client Portal | eleoro">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <div>
        <img class="mx-auto h-12 w-auto" src="/eleoro-logo-nobg.png" alt="eleoro">
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
          Client Portal
        </h2>
      </div>
      
      {message && (
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
          <span class="block sm:inline">{message}</span>
        </div>
      )}

      {error && (
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
          <span class="block sm:inline">{error}</span>
        </div>
      )}

      {!message && (
        <form class="mt-8 space-y-6" method="POST">
          <div class="rounded-md shadow-sm -space-y-px">
            <div>
              <label for="email-address" class="sr-only">Email address</label>
              <input id="email-address" name="email" type="email" autocomplete="email" required class="appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-t-md focus:outline-none focus:ring-indigo-600 focus:border-indigo-600 focus:z-10 sm:text-sm" placeholder="Email address">
            </div>
          </div>

          <div>
            <button type="submit" class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              Send magic link
            </button>
          </div>
        </form>
      )}

      <div class="mt-6">
        <p class="text-center text-xs text-gray-500">
          This portal is for eleoro deliverables only. Do not upload confidential client records.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
