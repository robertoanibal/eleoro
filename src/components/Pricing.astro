<!-- Pricing Section -->
<div class="eleoro-pricing-module">
	<section class="pricing-section" role="region" aria-labelledby="pricing-title" id="pricing">
		<div class="pricing-container">
			<h2 class="section-title">Pricing</h2>
			<p class="section-intro">One-time setup fee to get AI running for your business. Most clients start with one package and expand as they see results.</p>
			<div class="pricing-grid pricing-grid-3col">
				<!-- Starter -->
				<article class="pricing-card" aria-labelledby="starter-title">
					<div class="card-body">
						<h3 id="starter-title" class="plan-name">Starter</h3>
						<p class="plan-subtitle">1–2 core workflows. Ideal for firms automating their first process.</p>
						<div class="plan-price">$1,500</div>
						<table class="pricing-features-table">
							<thead>
								<tr>
									<th>What's included</th>
									<th>Business Benefit</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>Discovery and solution design</td>
									<td>Clear roadmap before we build anything</td>
								</tr>
								<tr>
									<td>1–2 workflow builds (e.g. follow-up + document drafting)</td>
									<td>Immediate time savings on your most repetitive tasks</td>
								</tr>
								<tr>
									<td>Integration with your existing tools</td>
									<td>Works with what you already use — no rip and replace</td>
								</tr>
								<tr>
									<td>Pilot and validation</td>
									<td>Tested before go-live so you know it works</td>
								</tr>
								<tr>
									<td>Team training and documentation</td>
									<td>Your team can run it independently from day one</td>
								</tr>
							</tbody>
						</table>
					</div>
					<div class="card-footer">
						<a href="#contact" class="cta-button" role="button" aria-label="Book discovery call for Starter">
						Book discovery call
						</a>
					</div>
				</article>

				<!-- Growth -->
				<article class="pricing-card" aria-labelledby="growth-title" style="border: 2px solid var(--color-accent);">
					<div class="card-body">
						<div class="card-header" style="margin-bottom: 0.5rem;">
							<span class="card-badge badge-standard">Most Popular</span>
						</div>
						<h3 id="growth-title" class="plan-name">Growth</h3>
						<p class="plan-subtitle">3–4 workflows covering intake, billing, follow-ups, and reporting.</p>
						<div class="plan-price">$3,000–$3,500</div>
						<table class="pricing-features-table">
							<thead>
								<tr>
									<th>What's included</th>
									<th>Business Benefit</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>Everything in Starter</td>
									<td>Full foundation from day one</td>
								</tr>
								<tr>
									<td>3–4 workflow builds across intake, billing, and follow-up</td>
									<td>End-to-end automation across your client lifecycle</td>
								</tr>
								<tr>
									<td>Private LLM and RAG options</td>
									<td>AI that understands your firm's data and documents</td>
								</tr>
								<tr>
									<td>Complex integrations and data orchestration</td>
									<td>Seamless connection across your existing software stack</td>
								</tr>
								<tr>
									<td>Post-launch optimization</td>
									<td>Continuous improvement as your workflows evolve</td>
								</tr>
							</tbody>
						</table>
					</div>
					<div class="card-footer">
						<a href="#contact" class="cta-button" role="button" aria-label="Book discovery call for Growth">
						Book discovery call
						</a>
					</div>
				</article>

				<!-- Custom / Enterprise -->
				<article class="pricing-card" aria-labelledby="custom-title">
					<div class="card-body">
						<h3 id="custom-title" class="plan-name">Custom</h3>
						<p class="plan-subtitle">For firms with complex systems, large teams, or enterprise-grade requirements.</p>
						<div class="plan-price">Contact us</div>
						<table class="pricing-features-table">
							<thead>
								<tr>
									<th>What's included</th>
									<th>Business Benefit</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>Everything in Growth</td>
									<td>Full Growth package as the foundation</td>
								</tr>
								<tr>
									<td>Unlimited workflow builds and major extensions</td>
									<td>Custom AI workers for every part of your operation</td>
								</tr>
								<tr>
									<td>Enterprise security and compliance review</td>
									<td>HIPAA-eligible, SOC 2–ready infrastructure</td>
								</tr>
								<tr>
									<td>Dedicated rollout and change management plan</td>
									<td>High adoption with minimal disruption to your team</td>
								</tr>
								<tr>
									<td>Ongoing health checks and priority support</td>
									<td>We stay engaged as your firm grows and changes</td>
								</tr>
							</tbody>
						</table>
					</div>
					<div class="card-footer">
						<a href="#contact" class="cta-button" role="button" aria-label="Contact us for Custom pricing">
						Get in touch
						</a>
					</div>
				</article>
			</div>
			<p class="section-intro"><br><strong>Note:</strong> Prices above reflect setup fees; actual costs may
			vary based on scope.<br>Monthly usage fees are billed separately.</p>
		</div>
	</section>
</div>
